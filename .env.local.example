# Force Supabase for all data (add/update/delete/view). Set to true to ignore Oracle.
# USE_SUPABASE_ONLY=true

# Supabase — for auth (login/signup). Required even when using Oracle for data.
# .env.local is gitignored; do not commit real keys here.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OAuth (optional): enable Google and/or GitHub in Supabase Dashboard > Authentication > Providers.
# Add Client ID and Client Secret from each provider. No extra env vars needed for OAuth.

# Oracle ATP — when set, app uses Oracle for data (Supabase still used for auth)
# REQUIRED: Download wallet, extract, then set:
# ORACLE_USER=klarity_app
# ORACLE_PASSWORD=your_app_password
# TNS_ADMIN=/path/to/extracted/wallet
# ORACLE_TNS_ALIAS=xxx_high (from tnsnames.ora in wallet)
# ORACLE_WALLET_PASSWORD=password_from_console_when_downloading

# Optional: for running migrations via npm run db:migrate
# DATABASE_URL=postgresql://...

# OCI Generative AI — for chat assistant, note refinement, and review summary
# Create API key: OCI Console → Generative AI → API Keys
# Policy: allow any-user to use generative-ai-family in compartment <name> where request.principal.type='generativeaiapikey'
# See: https://github.com/oracle-samples/oci-openai
# OCI_GENAI_API_KEY=your_oci_genai_api_key
# OCI_GENAI_REGION=us-ashburn-1
# OCI_GENAI_COMPARTMENT_ID=ocid1.compartment.oc1..aaaa...
# OCI_GENAI_MODEL=meta.llama-3.3-70b-instruct

# OpenAI — for voice transcription (Whisper) only
# Get from https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key
